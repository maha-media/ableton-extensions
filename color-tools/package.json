{
  "name": "ableton-color-tools",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/extension.js",
  "scripts": {
    "build": "tsc --noEmit && /usr/bin/node node_modules/tsx/dist/cli.mjs build.ts",
    "test": "/usr/bin/node --import tsx --test tests/*.test.ts",
    "start": "/usr/bin/node node_modules/tsx/dist/cli.mjs build.ts && extensions-cli run"
  },
  "dependencies": {
    "@ableton-extensions/sdk": "file:../extensions-sdk-1.0.0-beta.0/ableton-extensions-sdk-1.0.0-beta.0.tgz"
  },
  "devDependencies": {
    "@ableton-extensions/cli": "file:../extensions-sdk-1.0.0-beta.0/ableton-extensions-cli-1.0.0-beta.0.tgz",
    "@types/node": "^25.9.2",
    "esbuild": "0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
